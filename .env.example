# Anwendungskonfiguration
PORT=3000
APP_NAME=Task Notes App
APP_VERSION=1.0.0

# Backend → Datenbankverbindung (DB_HOST = Service-Name aus docker-compose.yml)
DB_HOST=postgres
DB_PORT=5432
DB_USER=taskuser
DB_PASSWORD=change_me
DB_NAME=tasknotes

# PostgreSQL Service (muss mit DB_USER / DB_PASSWORD / DB_NAME übereinstimmen)
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tasknotes
