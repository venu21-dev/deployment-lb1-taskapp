# Anwendungskonfiguration
PORT=3000
APP_NAME=Task Notes App
APP_VERSION=1.0.0

# ── C3 Render Cloud ───────────────────────────────────────────────────────────
# DATABASE_URL wird von Render automatisch bereitgestellt (Internal Database URL).
# Wenn DATABASE_URL gesetzt ist, werden die DB_* Variablen unten ignoriert.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── C1 Docker Compose lokal ───────────────────────────────────────────────────
# Wird genutzt wenn DATABASE_URL nicht gesetzt ist.
DB_HOST=postgres
DB_PORT=5432
DB_USER=taskuser
DB_PASSWORD=change_me
DB_NAME=tasknotes

# PostgreSQL Service (muss mit DB_USER / DB_PASSWORD / DB_NAME übereinstimmen)
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tasknotes
